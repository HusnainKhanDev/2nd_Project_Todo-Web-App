<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To-Do List Forms</title>
</head>

<style>
    /* General Reset */
body, h1, h2, p, input, textarea, button {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    line-height: 1.5;
    background: linear-gradient(120deg, #f6d365, #fda085);
    color: #333;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* .header {
    text-align: center;
    padding: 20px;
    background-color: rgba(255, 255, 255, 0.8);
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
}

.header h1 {
    font-size: 2.5rem;
    color: #f57c00;
}

.header p {
    font-size: 1rem;
    color: #333;
    margin-top: 5px;
} */

.form-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px;
    gap: 40px; /* Adds spacing between the forms */
}

.form-box {
    background: white;
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    width: 90%;
    max-width: 500px;
}

.form-box h2 {
    text-align: center;
    color: #f57c00;
    margin-bottom: 15px;
}

.form-box label {
    display: block;
    margin: 10px 0 5px;
    font-weight: bold;
}

.form-box input, .form-box textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 1rem;
    margin-bottom: 15px;
}

.form-box button {
    background-color: #f57c00;
    color: white;
    border: none;
    padding: 10px;
    border-radius: 5px;
    font-size: 1rem;
    cursor: pointer;
    width: 100%;
    transition: background-color 0.3s ease;
}

.form-box button:hover {
    background-color: #e65100;
}

.footer {
    text-align: center;
    background-color: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 10px 20px;
    margin-top: auto;
    font-size: 0.9rem;
}

@media (max-width: 768px) {
    .form-box {
        width: 95%;
    }
}

/* Header Styling */
.header {
    background-color: rgba(255, 255, 255, 0.8);
    padding: 20px;
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
    position: sticky; /* Makes the header stick to the top */
    top: 0; /* Position it at the top of the page */
    z-index: 100; /* Ensures the header stays on top of other content */
    width: 97%; /* Full width */
    left: 0;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
}

.header h1 {
    font-size: 2.5rem;
    color: #f57c00;
}

.nav-link {
    font-size: 1.2rem;
    color: #f57c00;
    text-decoration: none;
    padding: 10px 20px;
    border: 2px solid #f57c00;
    border-radius: 5px;
    transition: background-color 0.3s ease, color 0.3s ease;
}

.nav-link:hover {
    background-color: #f57c00;
    color: white;
}
.message-box {
    font-size: 1rem;
    color: #f57c00;
    margin-left: 20px; /* Adjusts positioning relative to heading */
}

</style>

<body>
    <header class="header">
        <div class="header-content">
            <h1>To-Do List Manager</h1>
            <div id="messageBox" class="message-box">Welcome to the To-Do List Manager!</div>
            <nav>
                <a href="" class="nav-link" id="homeLink">Home</a>
            </nav>
        </div>
    </header>
    <main class="form-section">
        <!-- Create Form -->
        <form class="form-box create-form" id="createForm">
            <h2>Create To-Do</h2>
            <label for="create-title">Title</label>
            <input type="text" id="create-title" name="title" placeholder="Enter title" required>
            
            <label for="create-description">Description</label>
            <textarea id="create-description" name="description" placeholder="Enter description" rows="4" required></textarea>
            
            <label for="create-end-date">End Date</label>
            <input type="date" id="create-end-date" name="endDate" required>
            
            <button type="submit">Create</button>
        </form>

        <!-- Update Form -->
        <form class="form-box update-form" id="updateform">
            <h2>Update To-Do</h2>
            <label for="existing-title">Existing Title</label>
            <input type="text" id="existing-title" name="Etitle" placeholder="Enter existing title" required>
            
            <label for="new-title">New Title</label>
            <input type="text" id="new-title" name="title" placeholder="Enter new title">
            
            <label for="update-description">Description</label>
            <textarea id="update-description" name="description" placeholder="Enter new description" rows="4" ></textarea>
            
            <label for="update-end-date">End Date</label>
            <input type="date" id="update-end-date" name="enddate">
            
            <button type="submit">Update</button>
        </form>
    </main>
    <footer class="footer">
        <p>&copy; 2024 To-Do List Manager</p>
        <hr>
        <p>Todos will be Automatically deleted when Expired.</p>
    </footer>
</body>

<script>

function ShowMessage(msg){
    let box = document.getElementById("messageBox")

    box.innerText = msg;

    setTimeout(()=>{
        box.innerText = "Welcome to the To-Do List Manager!";
    }, 3000)
}

//geting token---------------------------------------------------------------------------

let token = sessionStorage.getItem("authtoken");
document.getElementById("homeLink").href = `/login/to/display/${token}`;

//Create form request------------------------------------------------------------------------------------

let createform = document.getElementById("createForm")

createform.addEventListener('submit', async (event) => {
    event.preventDefault();

    let data = {
        title: document.getElementById("create-title").value,
        description: document.getElementById("create-description").value,
        endDate: document.getElementById("create-end-date").value,
    };

    try {
        // Send POST request
        let response = await fetch("/api/inserttask/list", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                Authorization: `Bearer ${token}`, // Authorization header with Bearer token
            },
            body: JSON.stringify(data),
        });

        // Clear the form
        createform.reset();

        // Parse the response JSON once
        let responseData = await response.json();

        // Check if the response is successful
        if (!response.ok) {
            ShowMessage(responseData.msg || "Error occurred while creating the task.");
            console.error("Error:", responseData);
        } else {
            ShowMessage(responseData.msg || "Task created successfully!");
        }
    } catch (error) {
        // Catch network or unexpected errors
        ShowMessage("An unexpected error occurred. Please try again.");
        console.error("Fetch Error:", error);
    }
});

// UPDATE FORM-------------------------------------------------------------------------------------------
let UpdateForm = document.getElementById("updateform")

UpdateForm.addEventListener('submit', async (e)=>{
    e.preventDefault();
        let data = {
            Etitle: document.getElementById("existing-title").value,
            title: document.getElementById("new-title").value,
            description: document.getElementById("update-description").value,
            endDate: document.getElementById("update-end-date").value
        }

    try{
        let response = await fetch("/api/todo/update", {
            method: "PATCH",
            headers:{
                "Content-Type": "application/json",
                Authorization: `Bearer ${token}`
            },
            body: JSON.stringify(data)
        })
        UpdateForm.reset();

        // Parse the response JSON once
        let responseData = await response.json();
        if(response.ok){
            ShowMessage(responseData.msg)
        }
        else{
            ShowMessage(responseData.msg || "Something Went Wrong")
        }
    }
    catch(err){
        ShowMessage("Error While Submitting Form")
        console.log(err)
    }
})



</script>

</html>
