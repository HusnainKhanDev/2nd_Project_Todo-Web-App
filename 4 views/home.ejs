<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To-Do List</title>
</head>

<style>
    /* General Reset */
body, h1, h2, p, a, button {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    overflow-x: hidden;

    font-family: 'Arial', sans-serif;
    line-height: 1.5;
    background: linear-gradient(100deg, #f6d365, #fda085);
    color: #333;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* Header Styling */
.header {
    background-color: rgba(255, 255, 255, 0.8);
    padding: 20px;
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
    position: sticky; /* Makes the header stick to the top */
    top: 0; /* Position it at the top of the page */
    z-index: 100; /* Ensures the header stays on top of other content */
    width: 97%; /* Full width */
    left: 0;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
}

.header h1 {
    font-size: 2.5rem;
    color: #f57c00;
}

.nav-link {
    font-size: 1.2rem;
    color: #f57c00;
    text-decoration: none;
    padding: 10px 20px;
    border: 2px solid #f57c00;
    border-radius: 5px;
    transition: background-color 0.3s ease, color 0.3s ease;
}

.nav-link:hover {
    background-color: #f57c00;
    color: white;
}


.todo-card {
    background: white;
    border-radius: 10px;
    padding: 20px;
    margin: 25px;
    margin-left: 20%;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.todo-card:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.8);
    background: rgb(250, 234, 210);
}

.todo-title {
    font-size: 1.8rem;
    color: #f57c00;
}

.todo-description {
    font-size: 1rem;
    color: #555;
}

.todo-dates p {
    font-size: 0.9rem;
    color: #666;
}

.delete-button {
    background-color: #ff5252;
    color: white;
    border: none;
    padding: 10px;
    border-radius: 5px;
    font-size: 1rem;
    cursor: pointer;
    align-self: flex-start;
    transition: background-color 0.3s ease;
}

.delete-button:hover {
    background-color: #d32f2f;
}

/* Footer Styling */
.footer {
    text-align: center;
    background-color: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 10px 20px;
    margin-top: auto;
    font-size: 0.9rem;
}

/* Responsive Design */
@media (max-width: 768px) {
    .todo-card {
        width: 95%;
    }
    
    .header-content {
        flex-direction: column;
        align-items: center;
    }
    
    .nav-link {
        margin-top: 10px;
    }
}

</style>

<body>
    <!-- Header Section -->
    <header class="header">
        <div class="header-content">
            <h1>Your To-Do List</h1>
            <nav>
                <a href="/forms" class="nav-link">Create & Update To-Dos</a>
            </nav>
        </div>
    </header>

    <!-- Main Content for To-Do List -->
    <main>
        <div class="todo-container">
            <% if (!ListData || ListData.length === 0) { %>
                <!-- Message for no tasks -->
                <div class="todo-card">
                    <h3 class="todo-title">Let's Create New To-Do's</h3>
                </div>
            <% } else { %>
                <% ListData.forEach(items => { %>
                    <div class="todo-card">
                        <h2 class="todo-title"><%= items.title %></h2>
                        <p class="todo-description"><%= items.description %></p>
                        <div class="todo-dates">
                            <p><strong>Created At:</strong> <%= new Date(items.createdAt).toLocaleDateString() %></p>
                            <p><strong>End Date:</strong> <%= new Date(items.endDate).toLocaleDateString() %></p>
                        </div>
                        <button class="delete-button" data-id="<%= items._id %>">Delete</button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
    

    <!-- Footer Section -->
    <footer class="footer">
        <p>&copy; 2024 To-Do List Manager</p>
    </footer>
</body>

<script>

// Delete Button Script------------------------------------------------------------------------------------------------

let btns = document.querySelectorAll(".delete-button") // array of all btns created by EJS foreach
let token = sessionStorage.getItem("authtoken")

btns.forEach((btn) => { // this loop is to attach eventlistner to all button 
    btn.addEventListener('click', async (e)=>{
        let id = e.target.getAttribute('data-id')// getting data from targeted element means which we clicked 

        let responce = await fetch(`/api/delete/${id}`, {
            method: "DELETE",
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            }
        })
        // console.log( await responce.json())
        if(responce.ok){
            console.log( await responce.json())
            window.location.href = `/login/to/display/${token}` //redirecting to display controller 
        }
    })
})

</script>



</html>
